# ─── LootFlow Environment Variables ─────────────────────────────────────────
# Copie este arquivo para .env e preencha com os valores do seu Firebase.
# O arquivo .env NUNCA deve ser commitado no Git (está no .gitignore).
#
# Como obter estes valores:
# 1. Acesse https://console.firebase.google.com
# 2. Crie/selecione seu projeto
# 3. Configurações ⚙️ → Seus apps → SDK de configuração → Configuração
# 4. Copie os valores do objeto firebaseConfig

VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
