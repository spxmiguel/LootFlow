rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // User data — only the authenticated owner can read/write
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public social surface. These docs must only contain privacy-filtered
    // aggregates, never raw drops, accounts, email, or history.
    match /publicProfiles/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.data.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /friendCodes/{code} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.uid == request.auth.uid;
    }

    // Convites e amizades só podem ser lidos pelas duas contas envolvidas.
    match /friendRequests/{requestId} {
      allow read: if request.auth != null
                  && request.auth.uid in [resource.data.senderId, resource.data.recipientId];
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.senderId
                    && request.resource.data.senderId != request.resource.data.recipientId
                    && request.resource.data.id == requestId;
      allow delete: if request.auth != null
                    && request.auth.uid in [resource.data.senderId, resource.data.recipientId];
      allow update: if false;
    }

    match /friendships/{friendshipId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.memberIds;
      allow create: if request.auth != null
                    && request.resource.data.id == friendshipId
                    && request.resource.data.memberIds.size() == 2
                    && request.auth.uid == request.resource.data.acceptedBy
                    && exists(/databases/$(database)/documents/friendRequests/$(friendshipId))
                    && get(/databases/$(database)/documents/friendRequests/$(friendshipId)).data.recipientId == request.auth.uid
                    && request.resource.data.memberIds.hasAll([
                      get(/databases/$(database)/documents/friendRequests/$(friendshipId)).data.senderId,
                      get(/databases/$(database)/documents/friendRequests/$(friendshipId)).data.recipientId
                    ]);
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.memberIds;
      allow update: if false;
    }

    // Device code auth (YouTube TV style flow)
    // - Unauthenticated Electron app creates a pending code
    // - Anyone can read (Electron polls for completion)
    // - Authenticated web user completes the code (writes tokens)
    // - Anyone can delete (cleanup)
    match /device_codes/{code} {
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.keys().hasAll(['status', 'createdAt', 'expiresAt']);
      allow read:   if true;
      allow update: if request.auth != null
                    && resource.data.status == 'pending'
                    && request.resource.data.status == 'authenticated';
      allow delete: if true;
    }
  }
}
