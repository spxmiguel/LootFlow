{
  "name": "lootflow",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac"
  },
  "build": {
    "appId": "io.github.spxmiguel.lootflow",
    "productName": "LootFlow",
    "icon": "build-assets/icon-512.png",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      { "from": "build-assets/", "to": "build-assets/" }
    ],
    "protocols": [
      { "name": "LootFlow Auth", "schemes": ["lootflow"] }
    ],
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["pkg"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "firebase": "^10.13.1",
    "framer-motion": "^11.5.4",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.5.3",
    "use-debounce": "^10.0.3",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.44",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vite-plugin-pwa": "^1.3.0"
  }
}
